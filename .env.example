OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small
REDIS_URL=redis://localhost:6379/0
WANDB_API_KEY=...
WANDB_PROJECT=staRT
# Required: your W&B entity (team/user). If empty, weave.init() fails silently
# and no traces or project UI are created. Find it in the wandb.ai URL path.
WANDB_ENTITY=your-entity
WEAVE_ENABLED=true
# Optional override; if empty, falls back to WANDB_ENTITY/WANDB_PROJECT.
WEAVE_PROJECT=
